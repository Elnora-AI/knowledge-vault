{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cache-cleanup.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cache-cleanup.py\"",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/update-vault-index.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/update-vault-index.py\"",
            "timeout": 60000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-vault-write.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-vault-write.py\"",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-task-move.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-task-move.py\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
